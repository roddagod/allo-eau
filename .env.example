# =============================================================================
# Plateforme Eau Libreville — Variables d'environnement
# Copier vers .env.local (racine) OU chaque apps/*/.env.local
# =============================================================================

# --- Supabase (obligatoire) --------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...          # server-only, jamais côté client

# --- Google OAuth (facultatif si non activé) ---------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- OpenRouteService (routing / ETA) ----------------------------------------
ORS_API_KEY=

# --- Cartes ------------------------------------------------------------------
NEXT_PUBLIC_PMTILES_URL=https://cdn.eaupourtous.ga/tiles/libreville.pmtiles

# --- URLs des apps (utilisées pour les liens croisés) ------------------------
NEXT_PUBLIC_CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_DRIVER_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002
